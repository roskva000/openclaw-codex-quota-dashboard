# Codex Quota Dashboard config

# OpenClaw binary
OPENCLAW_BIN=openclaw

# Provider to query
PROVIDER=openai-codex

# Dedicated agent for safe auth-order probing
AGENT_ID=quota
CREATE_AGENT=1
MODEL_ID=openai-codex/gpt-5.3-codex

# If relative, resolved under project root
AGENT_WORKSPACE=agent-workspace

# Dashboard web bind
PORT=8787
# auto = tailscale IPv4 if available, otherwise 127.0.0.1
BIND_HOST=auto

# Collector timeout in seconds
REFRESH_TIMEOUT=180
